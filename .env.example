# Production site URL (no trailing slash). Used for canonical URLs, Open Graph, and sitemap references.
# Copy to .env.local for local testing. GitHub Actions sets this automatically on deploy.
VITE_SITE_URL=https://www.nikoleglenn.com

# Optional: iframe src from LightWidget, SnapWidget, Elfsight, etc. for a live Instagram grid on the site.
# Example (LightWidget): https://cdn.lightwidget.com/widgets/your-widget-id.html
# For production, add the same value as a GitHub Actions secret: VITE_INSTAGRAM_FEED_EMBED_URL
VITE_INSTAGRAM_FEED_EMBED_URL=

# Live site: GitHub Pages (free). DNS in GoDaddy:
#   @  → A  185.199.108.153, 185.199.109.153, 185.199.110.153, 185.199.111.153
#   www → CNAME  tristandmartin.github.io
# HTTPS: enable in repo Settings → Pages → Enforce HTTPS (auto-enabled after deploy when cert exists).
# Apex (@) in GoDaddy: forward permanently to https://www.nikoleglenn.com (remove GitHub A records if using forwarding).
# www is canonical; CNAME www → tristandmartin.github.io.
# Optional GitHub secret for production Instagram embed: VITE_INSTAGRAM_FEED_EMBED_URL
